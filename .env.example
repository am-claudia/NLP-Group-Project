# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must never be committed.

# Google Custom Search API
# Get your API key:  https://console.developers.google.com -> Enable "Custom Search API" -> Credentials -> Create API key
# Get your CSE ID:   https://programmablesearchengine.google.com -> New search engine -> Search the entire web -> Copy ID
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_cse_id_here

# NCBI E-utilities (PubMed API)
# Any valid email address works — required by NCBI's terms of use
# Optional: get a free API key at https://www.ncbi.nlm.nih.gov/account/ to raise the rate limit from 3 to 10 req/sec
NCBI_EMAIL=your@email.com
NCBI_API_KEY=
